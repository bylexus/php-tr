{
    "name": "bylexus/durable-task",
    "description": "Durable task library for PHP backed by PostgreSQL.",
    "version": "0.0.1",
    "type": "library",
    "require": {
        "ext-pdo": "*",
        "php": "^8.3",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpmailer/phpmailer": "^7.0",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^3"
    },
    "autoload": {
        "psr-4": {
            "ByLexus\\DurableTask\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ByLexus\\DurableTask\\Tests\\": "tests/",
            "": [
                "examples/"
            ]
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "config": {
        "sort-packages": true
    }
}
