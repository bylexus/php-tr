{
    "name": "bylexus/php-tr",
    "description": "Queued Task worker library for PHP backed by PostgreSQL.",
    "type": "library",
    "license": "MIT",
    "require": {
        "ext-pdo": "*",
        "php": "^8.3",
        "psr/container": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpmailer/phpmailer": "^7.0",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^3"
    },
    "autoload": {
        "psr-4": {
            "ByLexus\\TaskRunner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ByLexus\\TaskRunner\\Tests\\": "tests/",
            "": [
                "examples/"
            ]
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "config": {
        "sort-packages": true
    }
}
